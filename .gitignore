data/group/

# Paper dataset and derived metadata
data/paper/*.xlsx
data/paper/*.xls
src/species_metadata.py

# Python artifacts
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.so
*.egg-info/
*.egg
build/
dist/

# Virtual environments
.venv/
venv/
env/
ENV/
.env
.env.*

# Jupyter / IPython
.ipynb_checkpoints/
*.ipynb_checkpoints

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
Thumbs.db
Desktop.ini
desktop.ini
.DS_Store

# Logs and temporary files
*.log
*.tmp
*.bak

# Testing / tooling caches
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.ruff_cache/
.pytype/
cython_debug/
